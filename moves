local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
	Name = "1",
	LoadingTitle = "1",
	LoadingSubtitle = "1",
	Theme = "DarkBlue",
	ToggleUIKeybind = "K",
	ConfigurationSaving = {
		Enabled = true,
		FolderName = "UnifiedHub",
		FileName = "Config"
	}
})

local OrbitTab = Window:CreateTab("orbit", "orbit")
local TeleportTab = Window:CreateTab("teleport", "user")
local WalkFlingTab = Window:CreateTab("walkfling", "zap")

local orbitConnection
local deathConnection
local seatConnection

local selectedPlayer
local originalCameraSubject

local speed = 90
local distance = 6

local function getRoot(character)
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function unorbit()
	if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
	if deathConnection then deathConnection:Disconnect() deathConnection = nil end
	if seatConnection then seatConnection:Disconnect() seatConnection = nil end

	if originalCameraSubject then
		workspace.CurrentCamera.CameraSubject = originalCameraSubject
	end
	originalCameraSubject = nil
end

local function startOrbit()
	unorbit()

	if not selectedPlayer or not selectedPlayer.Character then return end

	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local humanoid = character:FindFirstChildWhichIsA("Humanoid")
	local root = getRoot(character)
	local targetRoot = getRoot(selectedPlayer.Character)

	if not root or not targetRoot or not humanoid then return end

	originalCameraSubject = humanoid

	local rotation = 0

	local targetHumanoid = selectedPlayer.Character:FindFirstChildWhichIsA("Humanoid")
	if targetHumanoid then
		workspace.CurrentCamera.CameraSubject = targetHumanoid
	end

	orbitConnection = RunService.Heartbeat:Connect(function(dt)

		if not selectedPlayer or not selectedPlayer.Character then
			unorbit()
			return
		end

		local targetCharacter = selectedPlayer.Character
		local targetRoot = getRoot(targetCharacter)
		local targetHumanoid = targetCharacter:FindFirstChildWhichIsA("Humanoid")

		if targetHumanoid and workspace.CurrentCamera.CameraSubject ~= targetHumanoid then
			workspace.CurrentCamera.CameraSubject = targetHumanoid
		end

		if targetRoot and root and root.Parent then
			rotation += speed * dt
			local angleRad = math.rad(rotation)

			local offset = Vector3.new(
				math.cos(angleRad) * distance,
				0,
				math.sin(angleRad) * distance
			)

			local targetPos = targetRoot.Position

			root.CFrame = CFrame.new(targetPos + offset, targetPos)
		end
	end)

	deathConnection = humanoid.Died:Connect(unorbit)
	seatConnection = humanoid.Seated:Connect(function(active)
		if active then unorbit() end
	end)
end

OrbitTab:CreateSection("target")

local function getPlayerDisplayNames()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			table.insert(list, p.DisplayName .. " (@" .. p.Name .. ")")
		end
	end
	return list
end

local function getPlayerByDisplay(name)
	for _, p in ipairs(Players:GetPlayers()) do
		if p.DisplayName .. " (@" .. p.Name .. ")" == name then
			return p
		end
	end
end

local OrbitDropdown
OrbitDropdown = OrbitTab:CreateDropdown({
	Name = "select player",
	Options = getPlayerDisplayNames(),
	CurrentOption = {},
	MultipleOptions = false,
	Callback = function(opt)
		selectedPlayer = getPlayerByDisplay(opt[1])
	end
})

