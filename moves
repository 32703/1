LocalPlayer.CharacterAdded:Connect(function()
	task.wait(1)
	unorbit()
end)

local positionBehind = true
local distanceFromTarget = 4
local teleportEnabled = false
local cyclicTeleportEnabled = false
local selectedSinglePlayer = nil
local selectedPlayersList = {}
local currentIndex = 1

local function teleportToPlayer(targetPlayer)
	if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
	if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

	local localHRP = LocalPlayer.Character.HumanoidRootPart
	local targetHRP = targetPlayer.Character.HumanoidRootPart

	local offset = (positionBehind and -1 or 1) * targetHRP.CFrame.LookVector * distanceFromTarget
	localHRP.CFrame = CFrame.new(targetHRP.Position + offset, targetHRP.Position)
end

local function getDisplayNames()
	local list = {}
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			table.insert(list, p.DisplayName .. " (@" .. p.Name .. ")")
		end
	end
	return list
end

local function getPlayerByDisplay(name)
	for _, p in pairs(Players:GetPlayers()) do
		if p.DisplayName .. " (@" .. p.Name .. ")" == name then
			return p
		end
	end
end

TeleportTab:CreateSection("single")

local SingleDropdown
SingleDropdown = TeleportTab:CreateDropdown({
	Name = "select player",
	Options = getDisplayNames(),
	CurrentOption = {},
	Callback = function(opt)
		selectedSinglePlayer = getPlayerByDisplay(opt[1])
	end
})

TeleportTab:CreateToggle({
	Name = "teleport",
	CurrentValue = false,
