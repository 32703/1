TeleportTab:CreateSection("cyclic")

local CyclicDropdown
CyclicDropdown = TeleportTab:CreateDropdown({
	Name = "select players",
	Options = getDisplayNames(),
	CurrentOption = {},
	MultipleOptions = true,
	Callback = function(opts)
		selectedPlayersList = {}
		for _, name in pairs(opts) do
			local p = getPlayerByDisplay(name)
			if p then table.insert(selectedPlayersList, p) end
		end
	end
})

TeleportTab:CreateToggle({
	Name = "cyclic",
	CurrentValue = false,
	Callback = function(v)
		cyclicTeleportEnabled = v
	end
})

TeleportTab:CreateSection("settings")

TeleportTab:CreateToggle({
	Name = "behind target",
	CurrentValue = true,
	Callback = function(v)
		positionBehind = v
	end
})

TeleportTab:CreateSlider({
	Name = "distance",
	Range = {0.5, 15},
	Increment = 0.5,
	CurrentValue = 4,
	Callback = function(v)
		distanceFromTarget = v
	end
})

RunService.Heartbeat:Connect(function()
	if teleportEnabled and selectedSinglePlayer then
		teleportToPlayer(selectedSinglePlayer)
	end

	if cyclicTeleportEnabled and #selectedPlayersList > 0 then
		teleportToPlayer(selectedPlayersList[currentIndex])
	end
end)

task.spawn(function()
	while true do
		if cyclicTeleportEnabled and #selectedPlayersList > 0 then
			currentIndex += 1
			if currentIndex > #selectedPlayersList then currentIndex = 1 end
		end
		task.wait(2)
	end
end)

Players.PlayerAdded:Connect(function()
	local names = getDisplayNames()
	SingleDropdown:Refresh(names)
	CyclicDropdown:Refresh(names)
end)

Players.PlayerRemoving:Connect(function()
	local names = getDisplayNames()
	SingleDropdown:Refresh(names)
	CyclicDropdown:Refresh(names)
end)

local walkflinging = false
local desiredEnabled = false

local function getRoot(char)
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function noclip(enable)
	local char = LocalPlayer.Character
	if not char then return end
	for _, part in pairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = not enable
		end
	end
end

local function startWalkFling()
	if walkflinging then return end
	walkflinging = true

	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildWhichIsA("Humanoid")

	if hum then
		hum.Died:Connect(function()
			walkflinging = false
			noclip(false)
		end)
	end

	noclip(true)

	task.spawn(function()
		local movel = 0.1
		repeat
			RunService.Heartbeat:Wait()

			char = LocalPlayer.Character
			local root = getRoot(char)

			while not (char and root and root.Parent) do
				RunService.Heartbeat:Wait()
				char = LocalPlayer.Character
				root = getRoot(char)
			end

			local vel = root.Velocity
			root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)

			RunService.RenderStepped:Wait()
			if root then root.Velocity = vel end

			RunService.Stepped:Wait()
			if root then
				root.Velocity = vel + Vector3.new(0, movel, 0)
				movel = -movel
			end
		until not walkflinging

		noclip(false)
	end)
end

local function stopWalkFling()
	walkflinging = false
	noclip(false)
end

WalkFlingTab:CreateSection("movement")

WalkFlingTab:CreateToggle({
	Name = "walkfling",
	CurrentValue = false,
	Callback = function(v)
		desiredEnabled = v
		if v then startWalkFling() else stopWalkFling() end
	end
})

LocalPlayer.CharacterAdded:Connect(function()
	task.wait(0.2)
	if desiredEnabled then startWalkFling() end
end)

Rayfield:LoadConfiguration()
